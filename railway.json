{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install",
    "watchPatterns": [
      "**"
    ]
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/login.html",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "port": 3000
  },
  "environment": {
    "NODE_ENV": "production"
  }
}
